# Pets Plus Portal — Environment Config
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to GitHub.

# Port the portal runs on (default 3000)
PORT=3000

# Your GitHub repo (format: username/repo-name)
GITHUB_REPO=your-username/pets-plus

# Where to store submissions on the Pi
SUBMISSIONS_DIR=/home/pi/pets-plus-submissions
