    "Protects you":        { "minecraft:behavior.defend_trusted_target": { "priority": 1, "entity_types": [{ "filters": { "test": "is_family", "subject": "other", "value": "monster" }, "max_dist": 12 }] } },
    "Scares mobs":         { "minecraft:behavior.stomp_attack": { "priority": 2, "speed_multiplier": 1.0, "track_target": true } },
    "Digs for treasure":   { "minecraft:behavior.move_to_block": { "priority": 2, "speed_multiplier": 1.0, "search_range": 10, "search_height": 8 } }
  },

  "weapon_effects": {
    "Extra damage":  { "minecraft:weapon": { "damage": 8 } },
