    "Ocean":     { "spawns_underwater": true,   "height_max": 62,  "height_min": -20, "blocks": ["minecraft:sand","minecraft:gravel"] },
    "Desert":    { "spawns_underground": false, "height_max": 100, "height_min": 60,  "blocks": ["minecraft:sand","minecraft:sandstone"] },
    "Mountains": { "spawns_underground": false, "height_max": 200, "height_min": 100, "blocks": ["minecraft:stone","minecraft:snow"] }
  },

  "friendliness": {
    "Runs away":          { "flee_speed": 1.6, "flee_distance": 12 },
    "Ignores you":        { "flee_speed": 0.0, "flee_distance": 0  },
    "Follows you around": { "flee_speed": 0.0, "flee_distance": 0, "ambient_follow": true }
  },

  "creature_powers": {
