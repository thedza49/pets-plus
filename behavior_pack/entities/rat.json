{
  "format_version": "1.19.0",
  "minecraft:entity": {
    "description": {
      "identifier": "pets_plus:rat",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },

    "component_groups": {

      "pets_plus:untamed": {
        "minecraft:behavior.flee_from_target": {
          "priority": 1,
          "speed_multiplier": 1.4,
          "flee_distance": 10
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 2,
          "entity_types": [
            {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "value": "player"
              },
              "max_dist": 6
            }
          ]
        }
      },

      "pets_plus:tamed_following": {
        "minecraft:is_tamed": {},
        "minecraft:behavior.follow_owner": {
          "priority": 3,
          "speed_multiplier": 1.2,
          "start_distance": 10,
          "stop_distance": 2
        }
      },

      "pets_plus:tamed_sitting": {
        "minecraft:is_tamed": {},
        "minecraft:is_sitting": {},
        "minecraft:behavior.stay_while_sitting": {
          "priority": 2
        }
      },

      "pets_plus:scavenging": {
        "minecraft:is_tamed": {},
        "minecraft:behavior.pickup_items": {
          "priority": 2,
          "max_dist": 8,
          "goal_radius": 1.5,
          "speed_multiplier": 1.3,

          "items": [
            "minecraft:oak_log",
            "minecraft:spruce_log",
            "minecraft:birch_log",
            "minecraft:jungle_log",
            "minecraft:acacia_log",
            "minecraft:dark_oak_log",
            "minecraft:cobblestone",
            "minecraft:stone",
            "minecraft:coal",
            "minecraft:iron_ore",
            "minecraft:deepslate_iron_ore",
            "minecraft:raw_iron",
            "minecraft:raw_copper",
            "minecraft:copper_ore"
          ]
        },
        "minecraft:behavior.follow_owner": {
          "priority": 5,
          "speed_multiplier": 1.0,
          "start_distance": 16,
          "stop_distance": 3
        }
      }
    },

    "components": {

      "minecraft:type_family": {
        "family": ["rat", "mob", "animal"]
      },
      "minecraft:collision_box": {
        "width": 0.4,
        "height": 0.35
      },
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },

      "minecraft:health": {
        "value": 8,
        "max": 8
      },

      "minecraft:movement": {
        "value": 0.28
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:navigation.walk": {
        "can_path_over_water": false,
        "avoid_water": true,
        "avoid_damage_blocks": true,
        "can_path_from_air": false
      },

      "minecraft:nameable": {},

      "minecraft:leashable": {
        "soft_distance": 4,
        "hard_distance": 6,
        "on_leash": {
          "event": "pets_plus:on_leash",
          "target": "self"
        }
      },

      "minecraft:is_baby": {},

      "minecraft:tameable": {
        "probability": 0.33,
        "tame_items": ["minecraft:bread"],
        "tame_event": {
          "event": "pets_plus:on_tame",
          "target": "self"
        }
      },

      "minecraft:interact": {
        "interactions": [
          {
            "on_interact": {
              "filters": {
                "all_of": [
                  { "test": "is_family", "subject": "other", "value": "player" },
                  { "test": "is_sneaking", "subject": "other", "value": false },
                  { "test": "has_equipment", "subject": "other", "domain": "hand", "value": "pets_plus:rat_treat" }
                ]
              },
              "event": "pets_plus:cycle_mode",
              "target": "self"
            },
            "swing": true,
            "use_item": true,
            "play_sounds": "mob.cat.purr"
          }
        ]
      },

      "minecraft:behavior.random_stroll": {
        "priority": 9,
        "speed_multiplier": 0.8,
        "interval": 120
      },
      "minecraft:behavior.look_at_player": {
        "priority": 10,
        "look_distance": 6,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 10
      }
    },

    "events": {

      "pets_plus:on_tame": {
        "add": {
          "component_groups": ["pets_plus:tamed_following"]
        },
        "remove": {
          "component_groups": ["pets_plus:untamed"]
        }
      },

      "pets_plus:cycle_mode": {
        "sequence": [
          {
            "filters": {
              "test": "has_component",
              "value": "minecraft:is_sitting"
            },
            "add": { "component_groups": ["pets_plus:tamed_following"] },
            "remove": { "component_groups": ["pets_plus:tamed_sitting"] }
          },
          {
            "filters": {
              "test": "has_component",
              "operator": "!=",
              "value": "minecraft:is_sitting"
            },
            "add": { "component_groups": ["pets_plus:tamed_sitting"] },
            "remove": { "component_groups": ["pets_plus:tamed_following", "pets_plus:scavenging"] }
          }
        ]
      },

      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["pets_plus:untamed"]
        }
      }
    }
  }
}
